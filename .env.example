# Секретный ключ Django. Сгенерируйте свой и не храните его в открытом доступе.
SECRET_KEY=django-insecure-change-me

# Режим отладки. Для продакшена должен быть False.
DEBUG=True

# Разрешенные хосты через запятую, например: 127.0.0.1,localhost,example.com
ALLOWED_HOSTS=

# Настройки SMTP-бэкенда и почтового сервера.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.jino.ru
EMAIL_PORT=465

# Для Jino: SSL=True и TLS=False при порте 465.
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_TIMEOUT=60

# Учетные данные SMTP. Используйте полный адрес ящика и его пароль.
EMAIL_HOST_USER=recovery@kasago.ru
EMAIL_HOST_PASSWORD=your-mailbox-password

# Адрес отправителя исходящих писем.
DEFAULT_FROM_EMAIL=recovery@kasago.ru

# Отдельный адрес отправителя для писем восстановления пароля.
PASSWORD_RESET_FROM_EMAIL=recovery@kasago.ru

# Домен и протокол для ссылок в письмах восстановления пароля.
SITE_DOMAIN=kasago.ru
SITE_PROTOCOL=https

# Получатель писем из формы обратной связи.
FEEDBACK_RECIPIENT_EMAIL=feedback@kasago.ru