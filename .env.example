# Секретный ключ Django. Сгенерируйте свой и не храните его в открытом доступе.
SECRET_KEY=django-insecure-change-me

# Режим отладки. Для продакшена должен быть False.
DEBUG=True

# Разрешенные хосты через запятую, например: 127.0.0.1,localhost,example.com
ALLOWED_HOSTS=

# Настройки SMTP-бэкенда и почтового сервера.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mail.ru
EMAIL_PORT=465

# Для Mail.ru: SSL=True и TLS=False при порте 465.
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_TIMEOUT=60

# Учетные данные SMTP. Используйте пароль приложения Mail.ru.
EMAIL_HOST_USER=your-mailbox@mail.ru
EMAIL_HOST_PASSWORD=your-mail-ru-app-password

# Адрес отправителя исходящих писем.
DEFAULT_FROM_EMAIL=your-mailbox@mail.ru

# Получатель писем из формы обратной связи.
FEEDBACK_RECIPIENT_EMAIL=recipient@mail.ru